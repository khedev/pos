{
  "name": "pgpos",
  "private": true,
  "version": "1.0.0",
  "description": "PGPOS - Pharmacy & Grocery POS System",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./frontend\" --filter \"./backend\" dev",
    "dev:frontend": "pnpm --filter ./frontend dev",
    "dev:backend": "pnpm --filter ./backend dev",
    "build": "pnpm --filter pgpos-frontend run build",
    "seed": "pnpm --filter ./backend seed"
  }
}
